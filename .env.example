# ===========================================
# LivinWitFire — Shared Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit secrets.

# Anthropic API key (required for AI agent flows)
ANTHROPIC_API_KEY=sk-ant-...

# DoltgreSQL staging database connection string
DOLT_CONNECTION_STRING=postgresql://root:@localhost:5433/lwf_staging

# Neon production database connection string (optional — only for sync)
NEON_DATABASE_URL=
