# ===========================================
# LivinWitFire .gitignore
# ===========================================
# Strategy: Track ALL outputs (CSV, JSON, DB) so every dataset
# is available on clone. Only ignore raw source downloads and temp files.
# Files over 100MB are handled by Git LFS (see .gitattributes).

# ----- Environment variables (secrets) -----
.env

# ----- Source files (PDFs, ZIPs, XLSX, HTML originals) -----
# Reproducible from URLs documented in each folder's README.md
database-sources/**/Sources/
knowledge-base/**/Sources/
LivingWithFire-DB/Sources/

# ----- Scraping temp files -----
scrape_progress.json

# ----- OS and editor junk -----
.DS_Store
Thumbs.db
desktop.ini
__MACOSX/
*.swp
*.swo
*~
.vscode/
.idea/

# ----- Python -----
__pycache__/
*.pyc
*.pyo
venv/

# ----- DoltgreSQL staging database (local dev only) -----
lwf-staging/
.doltcfg/
auth.db

# ----- Genkit agent project -----
genkit/node_modules/
genkit/dist/

# ----- Admin portal (Next.js) -----
admin/node_modules/
admin/.next/

# ----- Temp/cache -----
*.tmp
*.bak
*.log
