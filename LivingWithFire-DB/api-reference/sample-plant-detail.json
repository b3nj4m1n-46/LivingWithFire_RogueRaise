      {
        "id": "159c6099-af98-411e-8483-52f02dbed80b",
        "attributeId": "34b147da-613b-4df7-8eb9-76fd10e1d7ae",
        "attributeName": "Flammability Notes",
        "plantId": "5b2ca061-b5b7-40fa-9941-269c17c52413",
        "rawValue": "Refer to Abelia x grandiflora. No cited evidence on flammability or claims of \"fire resistance\" for the entire genus. The plant character score suggests it is moderately flammable.",
        "resolved": {
          "value": "Refer to Abelia x grandiflora. No cited evidence on flammability or claims of \"fire resistance\" for the entire genus. The plant character score suggests it is moderately flammable.",
          "raw": "Refer to Abelia x grandiflora. No cited evidence on flammability or claims of \"fire resistance\" for the entire genus. The plant character score suggests it is moderately flammable.",
          "type": "text"
        },
