      },
      {
        "id": "c24c2145-3bc8-4af3-8518-78ba90406d19",
        "attributeId": "2cba404d-a80a-4cfd-abd9-c475237a06ec",
        "attributeName": "Risk Reduction Notes - Best Practices",
        "plantId": "5b2ca061-b5b7-40fa-9941-269c17c52413",
        "rawValue": "Short low flammability plants (<2 ft tall) are a better choice. Do not grow flammable plants under this plant. Prune base branches up 1 to 6 feet depending on plant size. Only grow on burnable mulches that are 10 or more feet from buildings. Remove dead and fine debris often. Papery or loose materials on a plant act as a fuel ladder. Plant at least 10 ft away from buildings. On flat ground, space 2 times the mature height of the plant. Increase spacing distance on slopes. A plant that has waxy leaves, contains volatile chemicals, or retains dead material can burn intensely and explosively. Avoid placing burnable mulch under the plant and remove other plants growing under it. If planted within 30 ft of a building, isolate it or replace with a less flammable plant.",
        "resolved": {
          "value": "Short low flammability plants (<2 ft tall) are a better choice. Do not grow flammable plants under this plant. Prune base branches up 1 to 6 feet depending on plant size. Only grow on burnable mulches that are 10 or more feet from buildings. Remove dead and fine debris often. Papery or loose materials on a plant act as a fuel ladder. Plant at least 10 ft away from buildings. On flat ground, space 2 times the mature height of the plant. Increase spacing distance on slopes. A plant that has waxy leaves, contains volatile chemicals, or retains dead material can burn intensely and explosively. Avoid placing burnable mulch under the plant and remove other plants growing under it. If planted within 30 ft of a building, isolate it or replace with a less flammable plant.",
          "raw": "Short low flammability plants (<2 ft tall) are a better choice. Do not grow flammable plants under this plant. Prune base branches up 1 to 6 feet depending on plant size. Only grow on burnable mulches that are 10 or more feet from buildings. Remove dead and fine debris often. Papery or loose materials on a plant act as a fuel ladder. Plant at least 10 ft away from buildings. On flat ground, space 2 times the mature height of the plant. Increase spacing distance on slopes. A plant that has waxy leaves, contains volatile chemicals, or retains dead material can burn intensely and explosively. Avoid placing burnable mulch under the plant and remove other plants growing under it. If planted within 30 ft of a building, isolate it or replace with a less flammable plant.",
          "type": "text"
        },
